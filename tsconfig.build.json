{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
